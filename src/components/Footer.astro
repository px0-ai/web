---
import { GITHUB, DOCS } from '../data/links';
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo-link">
        <img src="/logo/px0-logo-dark.png" alt="px0 Logo" class="logo-img logo-dark" />
        <img src="/logo/px0-logo-light.png" alt="px0 Logo" class="logo-img logo-light" />
      </a>
      <p>Open Source Prompt Infrastructure.</p>
    </div>
    <div class="footer-right">
      <div class="footer-links">
        <a class="footer-link" href={DOCS} target="_blank" rel="noopener noreferrer">Docs</a>
        <a class="footer-link" href={GITHUB} target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </div>
</footer>
