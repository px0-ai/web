---
import { DOCS, GITHUB } from '../data/links';

const templateCode = [
  '<span class="s-c">{{/* customer_support · v7 */}}</span>',
  '<span class="s-tag">{{</span> $tone := <span class="s-str">"friendly"</span> <span class="s-tag">}}{{</span> <span class="s-kw">if</span> <span class="s-fn">eq</span> .user.tier <span class="s-str">"enterprise"</span> <span class="s-tag">}}{{</span> $tone = <span class="s-str">"formal"</span> <span class="s-tag">}}{{</span> <span class="s-kw">end</span> <span class="s-tag">}}</span>',
  '',
  'You are a <span class="s-var">{{</span> $tone <span class="s-var">}}</span> assistant for <span class="s-var">{{</span> .company.name <span class="s-var">}}</span>.',
  'User: <span class="s-var">{{</span> .query <span class="s-var">}}</span>',
  'Lang: <span class="s-var">{{</span> <span class="s-fn">or</span> .lang <span class="s-str">"English"</span> <span class="s-var">}}</span>',
].join('\n');

const pythonCode = [
  '<span class="s-kw">import</span> px0',
  '',
  'prompt = px0.<span class="s-fn">render</span>(<span class="s-str">"customer_support"</span>, {',
  '    <span class="s-str">"user"</span>:    user,',
  '    <span class="s-str">"company"</span>: company,',
  '    <span class="s-str">"query"</span>:   query,',
  '})<span class="cursor"></span>',
].join('\n');

const nodeCode = [
  '<span class="s-kw">import</span> { px0 } <span class="s-kw">from</span> <span class="s-str">"px0"</span>',
  '',
  '<span class="s-kw">const</span> prompt = <span class="s-kw">await</span> px0.<span class="s-fn">render</span>(<span class="s-str">"customer_support"</span>, {',
  '  user, company, query,',
  '})<span class="cursor"></span>',
  '',
  '',
].join('\n');

const goCode = [
  'prompt, err := px0.<span class="s-fn">Render</span>(<span class="s-str">"customer_support"</span>,',
  '    map[string]any{',
  '        <span class="s-str">"user"</span>:    user,',
  '        <span class="s-str">"company"</span>: company,',
  '        <span class="s-str">"query"</span>:   query,',
  '    },',
  ')<span class="cursor"></span>',
].join('\n');
---

<section class="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="container hero-inner">

    <div class="hero-left">
      <div class="badge">
        <span class="badge-dot" aria-hidden="true"></span>
        open source &middot; prompt infrastructure
      </div>
      <h1>Prompts are code.<br>Treat them like&nbsp;it.</h1>
      <p class="hero-desc">
        An open-source prompt infrastructure. Move prompts into versioned
        templates with deploy-free updates and standard SDKs, so you can stop
        hardcoding and iterate securely.
      </p>
      <div class="cta-row">
        <a href={DOCS} class="btn-primary" target="_blank" rel="noopener noreferrer">
          Get Started
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <a href={GITHUB} class="btn-ghost" target="_blank" rel="noopener noreferrer">Star the Repo &rarr;</a>
      </div>
    </div>

    <div class="hero-right">
      <div class="terminal">
        <div class="t-header">
          <div class="t-dots" aria-hidden="true">
            <span></span><span></span><span></span>
          </div>
          <span class="t-name">customer_support.tmpl</span>
          <span class="t-ver">v7 &middot; live</span>
        </div>

        <div class="t-block">
          <div class="t-label">template</div>
          <pre class="t-code t-code-wrap" set:html={templateCode}></pre>
        </div>

        <div class="t-divider"></div>

        <div class="t-block">
          <div class="t-label">sdk call</div>
          <div class="lang-tabs">
            <button class="lang-tab active" data-lang="python">Python</button>
            <button class="lang-tab" data-lang="node">Node.js</button>
            <button class="lang-tab" data-lang="go">Go</button>
          </div>
          <pre class="t-code lang-pane active" id="lang-python" set:html={pythonCode}></pre>
          <pre class="t-code lang-pane" id="lang-node" set:html={nodeCode}></pre>
          <pre class="t-code lang-pane" id="lang-go" set:html={goCode}></pre>
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.lang-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.lang-pane').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById('lang-' + (tab as HTMLElement).dataset.lang)?.classList.add('active');
    });
  });
</script>
